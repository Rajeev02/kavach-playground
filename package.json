{
  "name": "kavach-playground",
  "version": "1.0.0",
  "description": "Public Demo Platform and Developer Playground for Kavach SDKs",
  "private": true,
  "workspaces": [
    "apps/*",
    "backend/*",
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present || true"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "eslint": "^9",
    "prettier": "^3.0.0",
    "tailwindcss": "3.3.2",
    "@tailwindcss/postcss": "^4"
  },
  "overrides": {
    "@tailwindcss/postcss": {
      "tailwindcss": "^4"
    }
  }
}
