{
  "name": "kavach-playground",
  "version": "1.0.0",
  "description": "Public Demo Platform and Developer Playground for Kavach SDKs",
  "private": true,
  "workspaces": [
    "apps/*",
    "backend/*",
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "eslint": "^8.0.0",
    "prettier": "^3.0.0"
  }
}
