# Database Connection URL (e.g., Neon or PostgreSQL)
DATABASE_URL="postgresql://user:password@host:port/database"

# Secret key for JWT signing (Should be long and random in production)
JWT_SECRET="fallback_secret_for_demo"

# Set to 'true' to allow login with a fixed OTP (123456) for demo purposes
DEMO_MODE="true"

# The port the API will run on locally
PORT="4000"
